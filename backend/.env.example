# Backend configuration. Copy to `backend/.env` and edit.
#
#   cp backend/.env.example backend/.env
#
# NEVER commit a real key. `.env` (and every `.env.*` except this file) is
# gitignored — keep it that way. All values below are configuration, not code:
# no provider, model ID, base URL, or key is hardcoded anywhere in the source.

# --- LLM provider ------------------------------------------------------------
# Which implementation of the LLMProvider interface answers. See
# backend/app/llm_provider.py.
#
#   stub  (default) Deterministic, offline. No key, no SDK, no network call.
#                   Tests and CI run on this — zero cloud dependency.
#   groq            Groq's OpenAI-compatible API over plain HTTPS. Touches no AWS
#                   Bedrock and no AWS IAM, so it works in AWS Academy Learner Lab.
#
# Leave unset (or set to `stub`) to run with no external dependency at all.
LLM_PROVIDER=stub

# --- groq ---------------------------------------------------------------------
# Required when LLM_PROVIDER=groq.

# Model name — configuration, never hardcoded. Any Groq-served model works;
# swap it without touching code. e.g. llama-3.3-70b-versatile
# LLM_MODEL=llama-3.3-70b-versatile

# Your Groq API key, from https://console.groq.com/keys — REAL KEYS NEVER GO IN
# THIS FILE, only in your local, gitignored `.env`.
# GROQ_API_KEY=

# Optional. Defaults to Groq's OpenAI-compatible base URL. Override to point at a
# proxy or another OpenAI-compatible gateway.
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional. Per-request timeout in seconds (default 30).
# LLM_TIMEOUT_SECONDS=30
